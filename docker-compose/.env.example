# Database Configuration
DB_USER=user
DB_PASSWORD=password
DB_NAME=appstack_db

# Initial Admin Credentials (used for seeder)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=Password123!

# Published Docker Hub namespace used by docker-compose.release.yml
DOCKER_NAMESPACE=andycyx

# Backend Configuration
BACKEND_INTERNAL_PORT=3000
BACKEND_EXTERNAL_PORT=4010
JWT_SECRET=your_jwt_secret_here
SIMPLE_AUTH_PASSWORD=your_admin_password_here
NODE_ENV=production
WEBSITE_DOMAIN=localhost:4010

# Security & CORS
# Comma-separated list of allowed origins (e.g., http://localhost:8080)
ALLOWED_ORIGINS=http://localhost:8080
# Set to true only if using HTTPS. For HTTP/LAN, keep as false.
COOKIE_SECURE=false

# Frontend Configuration
FRONTEND_EXTERNAL_PORT=4011
VITE_API_BASE_URL=http://localhost:4010/api
