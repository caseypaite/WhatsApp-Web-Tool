# Website Configuration
WEBSITE_DOMAIN=localhost:3000
SIMPLE_AUTH_PASSWORD=admin_secret_123

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/appstack_db

# Auth0 Configuration
AUTH0_AUDIENCE=https://YOUR_AUTH0_DOMAIN/api/v2/
AUTH0_ISSUER_BASE_URL=https://YOUR_AUTH0_DOMAIN/
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET

# OTP Configuration
OTP_GATEWAY_URL=https://external-otp-api.com/send
OTP_API_KEY=your_api_key_here
OTP_ENABLED=true
OTP_EXPIRATION_MINUTES=5
OTP_MAX_RETRIES=3

# Initial Admin Configuration
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change_this_password

# Server Configuration
PORT=3000
NODE_ENV=development
